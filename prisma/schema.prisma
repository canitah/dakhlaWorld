generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Users ───────────────────────────────────────────────
model User {
  id            Int      @id @default(autoincrement())
  email         String?  @unique
  phone         String?  @unique
  password_hash String
  role          String   // student | institution | admin
  status        String   @default("pending") // pending | active | suspended
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  student_profile     StudentProfile?
  institution_profile InstitutionProfile?
  otp_tokens          OtpToken[]

  @@map("users")
}

// ─── Student Profiles ────────────────────────────────────
model StudentProfile {
  id                Int      @id @default(autoincrement())
  user_id           Int      @unique
  student_type      String?  // local | international
  full_name         String?
  city              String?
  age_range         String?
  intended_field    String?
  personal_statement String?
  education_level   String?
  experience_level  String?
  learning_goal     String?
  cv_url            String?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  user              User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  applications      Application[]
  saved_admissions  SavedAdmission[]

  @@map("student_profiles")
}

// ─── Institution Profiles ────────────────────────────────
model InstitutionProfile {
  id            Int      @id @default(autoincrement())
  user_id       Int      @unique
  name          String
  category      String?
  city          String?
  description   String?
  contact_email String?
  status        String   @default("pending") // pending | approved | rejected
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  user             User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  programs         Program[]
  payment_requests PaymentRequest[]

  @@map("institution_profiles")
}

// ─── Programs ────────────────────────────────────────────
model Program {
  id                 Int      @id @default(autoincrement())
  institution_id     Int
  title              String
  category           String?
  duration           String?
  eligibility        String?
  deadline           DateTime?
  application_method String?  // internal | external
  external_url       String?
  is_active          Boolean  @default(true)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  institution      InstitutionProfile @relation(fields: [institution_id], references: [id], onDelete: Cascade)
  applications     Application[]
  saved_admissions SavedAdmission[]

  @@index([institution_id])
  @@index([category])
  @@index([is_active])
  @@map("programs")
}

// ─── Applications ────────────────────────────────────────
model Application {
  id         Int      @id @default(autoincrement())
  program_id Int
  student_id Int
  status     String   @default("submitted") // submitted | viewed | accepted | rejected
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  program Program        @relation(fields: [program_id], references: [id], onDelete: Cascade)
  student StudentProfile @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([program_id, student_id]) // prevent duplicate applications
  @@index([student_id])
  @@index([program_id])
  @@map("applications")
}

// ─── Saved Admissions ────────────────────────────────────
model SavedAdmission {
  id         Int      @id @default(autoincrement())
  student_id Int
  program_id Int
  created_at DateTime @default(now())

  student StudentProfile @relation(fields: [student_id], references: [id], onDelete: Cascade)
  program Program        @relation(fields: [program_id], references: [id], onDelete: Cascade)

  @@unique([student_id, program_id])
  @@map("saved_admissions")
}

// ─── Payment Plans ───────────────────────────────────────
model PaymentPlan {
  id           Int    @id @default(autoincrement())
  name         String @unique // Free | Basic | Featured
  price_pkr    Int
  features_json String? // JSON string of features

  payment_requests PaymentRequest[]

  @@map("payment_plans")
}

// ─── Payment Requests ────────────────────────────────────
model PaymentRequest {
  id              Int      @id @default(autoincrement())
  institution_id  Int
  plan_id         Int
  transaction_ref String?
  screenshot_url  String?
  status          String   @default("pending") // pending | approved | rejected
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  institution InstitutionProfile @relation(fields: [institution_id], references: [id], onDelete: Cascade)
  plan        PaymentPlan        @relation(fields: [plan_id], references: [id])

  @@index([institution_id])
  @@map("payment_requests")
}

// ─── OTP Tokens ──────────────────────────────────────────
model OtpToken {
  id         Int      @id @default(autoincrement())
  user_id    Int
  code       String
  type       String   // signup | login | reset
  expires_at DateTime
  used       Boolean  @default(false)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("otp_tokens")
}

// ─── Categories ──────────────────────────────────────────
model Category {
  id   Int    @id @default(autoincrement())
  name String @unique

  @@map("categories")
}

// ─── Cities ──────────────────────────────────────────────
model City {
  id   Int    @id @default(autoincrement())
  name String @unique

  @@map("cities")
}
