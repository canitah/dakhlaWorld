generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  Int                 @id @default(autoincrement())
  email               String?             @unique
  phone               String?             @unique
  password_hash       String
  role                String
  status              String              @default("pending")
  created_at          DateTime            @default(now())
  updated_at          DateTime            @updatedAt
  institution_profile InstitutionProfile?
  notifications       Notification[]
  otp_tokens          OtpToken[]
  student_profile     StudentProfile?

  @@map("users")
}

model StudentProfile {
  id                  Int              @id @default(autoincrement())
  user_id             Int              @unique
  student_type        String?
  full_name           String?
  city                String?
  age_range           String?
  intended_field      String?
  personal_statement  String?
  education_level     String?
  experience_level    String?
  learning_goal       String?
  cv_url              String?
  created_at          DateTime         @default(now())
  updated_at          DateTime         @updatedAt
  profile_picture_url String?
  preferred_schedule  String?
  budget_min          Int?
  budget_max          Int?
  preferred_field     String?
  applications        Application[]
  saved_admissions    SavedAdmission[]
  user                User             @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("student_profiles")
}

model InstitutionProfile {
  id                  Int              @id @default(autoincrement())
  user_id             Int              @unique
  name                String
  category            String?
  city                String?
  description         String?
  contact_email       String?
  status              String           @default("pending")
  created_at          DateTime         @default(now())
  updated_at          DateTime         @updatedAt
  rejection_reason    String?
  profile_picture_url String?
  user                User             @relation(fields: [user_id], references: [id], onDelete: Cascade)
  payment_requests    PaymentRequest[]
  programs            Program[]

  @@map("institution_profiles")
}

model Program {
  id                 Int                @id @default(autoincrement())
  institution_id     Int
  title              String
  category           String?
  duration           String?
  eligibility        String?
  deadline           DateTime?
  application_method String?
  external_url       String?
  is_active          Boolean            @default(true)
  created_at         DateTime           @default(now())
  updated_at         DateTime           @updatedAt
  program_code       String             @unique @db.VarChar(255)
  fee                Int?
  schedule_type      String?
  study_field        String?
  applications       Application[]
  institution        InstitutionProfile @relation(fields: [institution_id], references: [id], onDelete: Cascade)
  saved_admissions   SavedAdmission[]

  @@index([institution_id])
  @@index([category])
  @@index([is_active])
  @@map("programs")
}

model Application {
  id               Int            @id @default(autoincrement())
  program_id       Int
  student_id       Int
  status           String         @default("submitted")
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt
  application_code String         @unique @db.VarChar(255)
  program          Program        @relation(fields: [program_id], references: [id], onDelete: Cascade)
  student          StudentProfile @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([program_id, student_id])
  @@index([student_id])
  @@index([program_id])
  @@map("applications")
}

model SavedAdmission {
  id         Int            @id @default(autoincrement())
  student_id Int
  program_id Int
  created_at DateTime       @default(now())
  program    Program        @relation(fields: [program_id], references: [id], onDelete: Cascade)
  student    StudentProfile @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([student_id, program_id])
  @@map("saved_admissions")
}

model PaymentPlan {
  id               Int              @id @default(autoincrement())
  name             String           @unique
  price_pkr        Int
  features_json    String?
  payment_requests PaymentRequest[]

  @@map("payment_plans")
}

model PaymentRequest {
  id              Int                @id @default(autoincrement())
  institution_id  Int
  plan_id         Int
  transaction_ref String?
  screenshot_url  String?
  status          String             @default("pending")
  created_at      DateTime           @default(now())
  updated_at      DateTime           @updatedAt
  institution     InstitutionProfile @relation(fields: [institution_id], references: [id], onDelete: Cascade)
  plan            PaymentPlan        @relation(fields: [plan_id], references: [id])

  @@index([institution_id])
  @@map("payment_requests")
}

model OtpToken {
  id         Int      @id @default(autoincrement())
  user_id    Int
  code       String
  type       String
  expires_at DateTime
  used       Boolean  @default(false)
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("otp_tokens")
}

model Category {
  id   Int    @id @default(autoincrement())
  name String @unique

  @@map("categories")
}

model City {
  id   Int    @id @default(autoincrement())
  name String @unique

  @@map("cities")
}

model Notification {
  id         Int      @id @default(autoincrement())
  user_id    Int
  title      String
  message    String
  type       String
  is_read    Boolean  @default(false)
  link       String?
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("notifications")
}
